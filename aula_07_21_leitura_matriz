# Exemplo simples de matriz em Python (lista de listas)

matriz = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]

# Percorrendo e exibindo a matriz
print("Matriz:")
for linha in matriz:
    print(linha)

# Acessando um elemento específico (linha 1, coluna 2)
print("\nElemento na linha 1, coluna 2:", matriz[1][2])

# Somando todos os elementos da matriz
soma = 0
for linha in matriz:
    for elemento in linha:
        soma += elemento

print("Soma de todos os elementos:", soma)

# Calculando a soma de cada linha
print("\nSoma de cada linha:")
for i, linha in enumerate(matriz):
    print(f"Linha {i}: {sum(linha)}")